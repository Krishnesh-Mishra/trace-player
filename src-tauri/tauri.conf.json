{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trace Player",
  "version": "0.1.0",
  "identifier": "com.krish.traceplayer",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trace Player",
        "width": 1280,
        "height": 720,
        "minWidth": 640,
        "minHeight": 360,
        "resizable": true,
        "transparent": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/shaders/*.glsl"
    ],
    "fileAssociations": [
      {
        "ext": ["mp4", "mkv", "avi", "mov", "webm", "m4v", "ts", "flv", "wmv"],
        "name": "Video",
        "description": "Video file",
        "role": "Viewer"
      }
    ]
  }
}
